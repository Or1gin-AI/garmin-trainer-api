# ===== Application =====
NODE_ENV=production
APP_PORT=4001
PORT=4001

# Comma-separated frontend origins allowed to call this API
CORS_ORIGINS=https://garmin-trainer.uk,https://www.garmin-trainer.uk

# ===== BetterAuth =====
# openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of THIS api server
BETTER_AUTH_URL=https://api.garmin-trainer.uk
# Trusted frontend origins (cross-origin auth)
BETTER_AUTH_TRUSTED_ORIGINS=https://garmin-trainer.uk,https://www.garmin-trainer.uk

# ===== App-level encryption =====
# 32-byte high-entropy. Rotating invalidates all stored Garmin sessions.
APP_ENCRYPTION_KEY=

# ===== Database =====
# Used by app + worker + migrate via DATABASE_URL composed in docker-compose.yml
POSTGRES_USER=garmin
POSTGRES_PASSWORD=
POSTGRES_DB=garmin_trainer
POSTGRES_PORT=5556

# Persistent data dirs (relative to compose project, or absolute on host)
POSTGRES_DATA_DIR=./data/postgres
APP_DATA_DIR=./data/app

# ===== Image registry (set by deploy environment) =====
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=or1gin-ai/garmin-trainer-api
DOCKER_IMAGE_TAG=latest-dev

# ===== Garmin =====
GARMIN_HTTP_TIMEOUT_MS=30000
