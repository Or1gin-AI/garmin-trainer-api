# --- Server ---
PORT=4000
NODE_ENV=development
# Comma-separated origins allowed to call this API (frontend dev server, prod web origin)
CORS_ORIGINS=http://localhost:3001

# --- Postgres ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/garmin_trainer

# --- BetterAuth ---
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-long-random-string
# Public URL of THIS api server (used by BetterAuth for cookie / redirect URLs)
BETTER_AUTH_URL=http://localhost:4000
# Trusted frontend origins (BetterAuth uses this to allow cross-origin auth requests)
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001

# --- App-level encryption (Garmin passwords / sessions) ---
# 32-byte high-entropy string. Rotating invalidates all stored Garmin sessions.
APP_ENCRYPTION_KEY=replace-with-a-long-random-string

# --- Garmin sync ---
GARMIN_HTTP_TIMEOUT_MS=30000
